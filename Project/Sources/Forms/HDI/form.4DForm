					"top": 145,
					"left": 40,
					"width": 280,
					"height": 52,
					"fontFamily": "System Font",
					"fontSize": 14,
					"fontWeight": "bold",
					"text": "… validate a JSON document with the new JSON Validate command?"
				},
				"TxtSorry2": {
					"type": "text",
					"top": 120,
					"left": 20,
					"width": 320,
					"height": 86,
					"visibility": "hidden",
					"textAlign": "center",
					"fontFamily": "System Font",
					"fontSize": 14,
					"fontWeight": "bold",
					"text": "Sorry, this “How do I” (HDI) \rexample must be used with\ra newer version of 4D\r(v16 R4 and above)."
